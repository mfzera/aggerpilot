# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit secrets.

# SSH / SFTP credentials for the VPS that holds incoming proposals
SSH_HOST="your.vps.host"
SSH_USER="root"
SSH_PASS="change-me"

# PostgreSQL connection
DB_HOST="your.db.host"
DB_NAME="your_db_name"
DB_USER="postgres"
DB_PASS="change-me"
DB_PORT=5432

# Remote path on the VPS where proposal files are dropped
REMOTO_PDFS="/path/on/vps/to/propostas"

# Local working folder for downloaded proposals (Windows path)
LOCAL_PROPOSTAS="C:/Users/<you>/automacao/propostas_vps"
